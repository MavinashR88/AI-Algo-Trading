# =============================================================================
# AI Algo Trading System — Environment Variables
# Copy this to .env and fill in your values. NEVER commit .env to git.
# =============================================================================

# --- Alpaca (US Markets) ---
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key

# --- Zerodha Kite Connect (India Markets) ---
ZERODHA_API_KEY=your_zerodha_api_key
ZERODHA_ACCESS_TOKEN=your_zerodha_access_token
ZERODHA_API_SECRET=your_zerodha_api_secret

# --- Anthropic (Claude AI for Sentiment Analysis) ---
ANTHROPIC_API_KEY=your_anthropic_api_key

# --- NewsAPI (Free tier: 100 requests/day) ---
NEWSAPI_KEY=your_newsapi_key

# --- Email Notifications (Gmail SMTP) ---
EMAIL_SENDER=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
EMAIL_RECIPIENTS=recipient1@email.com,recipient2@email.com

# --- SMS Notifications (Twilio) ---
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890
TWILIO_TO_NUMBER=+1234567890
